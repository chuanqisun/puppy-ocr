{
  "name": "life-config",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently npm:dev:*",
    "dev:web": "vite",
    "dev:worker": "npm --prefix worker run dev",
    "worker": "npm --prefix worker run dev",
    "worker:deploy": "npm --prefix worker run deploy",
    "worker:test": "npm --prefix worker run test",
    "test": "npm run worker:test",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "pdf-lib": "^1.17.1",
    "rxjs": "^7.8.2"
  },
  "workspaces": [
    "worker"
  ]
}
