{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "puppy-ocr-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-10",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": ["nodejs_compat"],
	"vars": {
		"OCR_API_URL": "https://89f849v6s7oe6fea.aistudio-app.com/layout-parsing"
	}
